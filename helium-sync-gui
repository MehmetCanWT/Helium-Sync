                self.style(), QtWidgets.QStyle.StandardPixmap.SP_ComputerIcon
            ))

        self.tray_menu = QtWidgets.QMenu()
        show_action = QtGui.QAction("Open Settings App", self)
        show_action.triggered.connect(self.show_normal_window)
        
        quit_action = QtGui.QAction("Quit Application", self)
        quit_action.triggered.connect(self.quit_application)
        
        self.tray_menu.addAction(show_action)
        self.tray_menu.addSeparator()
        self.tray_menu.addAction(quit_action)
        
        self.tray_icon.setContextMenu(self.tray_menu)
        self.tray_icon.show()
        self.tray_icon.activated.connect(self.tray_icon_activated)

    def show_normal_window(self):
        self.show()
        self.raise_()
        self.activateWindow()

    def tray_icon_activated(self, reason):
        if reason == QtWidgets.QSystemTrayIcon.ActivationReason.Trigger:
            self.show_normal_window()

    def closeEvent(self, event: QtGui.QCloseEvent):
        # Intercept close event to hide instead of quit
        event.ignore()
        self.hide()
        self.tray_icon.showMessage(
            "Helium Sync",
            "Uygulama arka planda çalışmaya devam ediyor.",
            QtWidgets.QSystemTrayIcon.MessageIcon.Information,
            2000
        )

    def quit_application(self):
        self.tray_icon.hide()
        QtWidgets.QApplication.quit()

    # ─── LOGIC & API INTEGRATION ───

    def refresh_status(self):
        status_data = api_get("status")
        if not status_data:
            return

        # Update Header version
        app_ver = status_data.get("app_version", "0.5.0")
        self.subtitle_label.setText(f"Cloud Synchronizer & DRM Fixer • v{app_ver}")

        # Update Cards
        provider = status_data.get("provider", "none")
        provider_name = "None"
        if provider == "github_gist":
            provider_name = "GitHub Gist"
        elif provider == "webdav":
            provider_name = "WebDAV"
        self.card_provider.val_lbl.setText(provider_name)

        last_time = status_data.get("last_sync_time", "Never synchronized")
        self.card_time.val_lbl.setText(last_time)

        last_bytes = status_data.get("last_sync_size_bytes", 0)
        self.card_size.val_lbl.setText(self.format_bytes(last_bytes))

        enc = status_data.get("encryption_active", False)
        self.card_encryption.val_lbl.setText("Enabled (AES-256)" if enc else "Disabled")
        self.card_encryption.val_lbl.setStyleSheet(
            "color: #34D399; font-weight: 700;" if enc else "color: #F59E0B; font-weight: 700;"
        )

        # Check Browser Running Warning
        browser_run = status_data.get("browser_running", False)
        if browser_run:
            self.warn_banner.setText(
                "⚠️ Warning: Helium Browser is currently running. "
                "Manual synchronization or restore operations are DISABLED to prevent profile corruption. "
                "Please close the browser first."
            )
            self.warn_banner.show()
            self.btn_sync.setEnabled(False)
            self.btn_restore.setEnabled(False)
        else:
            self.warn_banner.hide()
            self.btn_sync.setEnabled(provider != "none")
            self.btn_restore.setEnabled(provider != "none")

    def format_bytes(self, num_bytes):
        if num_bytes == 0:
            return '0 Bytes'
        for unit in ['Bytes', 'KB', 'MB', 'GB']:
            if num_bytes < 1024.0:
                return f"{num_bytes:.2f} {unit}"
            num_bytes /= 1024.0
        return f"{num_bytes:.2f} GB"

    def refresh_logs(self):
        log_data = api_get("logs")
        if log_data and "logs" in log_data:
            lines = log_data["logs"]
            self.logs_view.setPlainText("\n".join(lines))
            # Scroll to bottom
            self.logs_view.verticalScrollBar().setValue(
                self.logs_view.verticalScrollBar().maximum()
            )

    def clear_logs(self):
        self.logs_view.clear()

    def toggle_provider_fields(self, index):
        provider = self.combo_provider.currentText()
        if provider == "GitHub Gist":
            self.gist_group.show()
            self.webdav_group.hide()
        elif provider == "WebDAV":
            self.gist_group.hide()
            self.webdav_group.show()
        else:
            self.gist_group.hide()
            self.webdav_group.hide()

    def toggle_encryption_fields(self, state):
        self.enc_pass_widget.setVisible(state == 2) # 2 means checked

    def browse_profile_path(self):
        dir_path = QtWidgets.QFileDialog.getExistingDirectory(self, "Select Helium Profile Directory")
        if dir_path:
            self.input_profile.setText(dir_path)

    def load_settings(self):
        config = api_get("settings")
        if not config:
            return

        provider = config.get("provider", "none")
        if provider == "github_gist":
            self.combo_provider.setCurrentText("GitHub Gist")
        elif provider == "webdav":
            self.combo_provider.setCurrentText("WebDAV")
        else:
            self.combo_provider.setCurrentText("None")

        self.input_profile.setText(config.get("profile_path", ""))
        self.input_token.setText(config.get("github_token", ""))
        self.input_gist_id.setText(config.get("github_gist_id", ""))
        self.input_wd_url.setText(config.get("webdav_url", ""))
        self.input_wd_user.setText(config.get("webdav_username", ""))
        self.input_wd_pass.setText(config.get("webdav_password", ""))
        self.input_wd_folder.setText(config.get("webdav_folder", "helium-sync"))

        enc_active = config.get("encryption_active", False)
        self.check_enc.setChecked(enc_active)
        self.input_enc_pass.setText(config.get("encryption_password", ""))
        self.enc_pass_widget.setVisible(enc_active)

    def save_settings(self):
        provider_text = self.combo_provider.currentText()
        provider = "none"
        if provider_text == "GitHub Gist":
            provider = "github_gist"
        elif provider_text == "WebDAV":
            provider = "webdav"

        payload = {
            "provider": provider,
            "profile_path": self.input_profile.text().strip(),
            "github_token": self.input_token.text().strip(),
            "github_gist_id": self.input_gist_id.text().strip(),
            "webdav_url": self.input_wd_url.text().strip(),
            "webdav_username": self.input_wd_user.text().strip(),
            "webdav_password": self.input_wd_pass.text().strip(),
            "webdav_folder": self.input_wd_folder.text().strip(),
            "encryption_active": self.check_enc.isChecked(),
            "encryption_password": self.input_enc_pass.text().strip(),
        }

        if api_post("settings", payload):
            QtWidgets.QMessageBox.information(self, "Success", "Configuration settings saved successfully!")
            self.refresh_status()
        else:
            QtWidgets.QMessageBox.critical(self, "Error", "Failed to save configuration settings.")

    def trigger_sync(self):
        if api_post("sync"):
            QtWidgets.QMessageBox.information(self, "Success", "Manual synchronization (Push) triggered successfully!")
            self.refresh_status()
            self.refresh_logs()
        else:
            QtWidgets.QMessageBox.critical(self, "Error", "Failed to trigger manual synchronization.")

    def trigger_restore(self):
        reply = QtWidgets.QMessageBox.question(
            self, "Restore Cloud Backup",
            "Are you sure you want to download and restore the profile from cloud?\n"
            "This will completely overwrite your current local browser profile!",
            QtWidgets.QMessageBox.StandardButton.Yes | QtWidgets.QMessageBox.StandardButton.No
        )
        if reply == QtWidgets.QMessageBox.StandardButton.Yes:
            if api_post("restore"):
                QtWidgets.QMessageBox.information(self, "Success", "Manual restore (Pull) completed successfully!")
                self.refresh_status()
                self.refresh_logs()
            else:
                QtWidgets.QMessageBox.critical(self, "Error", "Failed to restore cloud backup.")

    def trigger_fix_drm(self):
        if api_post("fix-drm"):
            QtWidgets.QMessageBox.information(self, "Success", "Widevine DRM fix applied successfully!")
            self.refresh_status()
            self.refresh_logs()
        else:
            QtWidgets.QMessageBox.critical(self, "Error", "Failed to apply Widevine DRM fix.")

def main():
    if not is_daemon_running():
        start_daemon()

