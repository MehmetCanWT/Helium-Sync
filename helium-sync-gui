def is_daemon_running() -> bool:
    try:
        response = urllib.request.urlopen(f"{API_URL}/status", timeout=1)
        return response.getcode() == 200
    except Exception:
        return False

def start_daemon():
    try:
        subprocess.run(["systemctl", "--user", "start", "helium-sync"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass
    for _ in range(6):
        if is_daemon_running():
            return True
        time.sleep(0.5)
    try:
        subprocess.Popen(["helium-sync-daemon"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass
    for _ in range(6):
        if is_daemon_running():
            return True
        time.sleep(0.5)
    return False

def api_get(endpoint: str) -> Optional[Dict[str, Any]]:
    try:
        response = urllib.request.urlopen(f"{API_URL}/{endpoint}", timeout=2)
        return json.loads(response.read().decode("utf-8"))
    except Exception:
        return None

def api_post(endpoint: str, data: Optional[Dict[str, Any]] = None) -> bool:
    try:
        req_data = json.dumps(data).encode("utf-8") if data else b""
        req = urllib.request.Request(
            f"{API_URL}/{endpoint}",
            data=req_data,
            headers={"Content-Type": "application/json"} if data else {}
        )
        with urllib.request.urlopen(req, timeout=10) as response:
            return response.getcode() == 200
    except Exception as e:
        print(f"API POST Error ({endpoint}):", e)
        return False

